{
  "name": "@crawlertoll/core",
  "version": "0.2.0",
  "description": "Open-source, framework-agnostic Node middleware for the AI-crawler economy. Bot detection, Web Bot Auth (IETF draft-meunier) verification, HTTP 402 issuance (Cloudflare crawler-price spec), and RSL 1.0 robots.txt parser/generator. Vendor-neutral; ships adapters TO Cloudflare PPC, TollBit, Skyfire, and x402.",
  "license": "Apache-2.0",
  "author": "Charthouse Ltd",
  "homepage": "https://crawlertoll.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nhrzxxw9dn-web/crawlertoll-core-js.git"
  },
  "bugs": {
    "url": "https://github.com/nhrzxxw9dn-web/crawlertoll-core-js/issues"
  },
  "keywords": [
    "ai-crawler",
    "pay-per-crawl",
    "web-bot-auth",
    "rsl",
    "rsl-1.0",
    "llms-txt",
    "bot-detection",
    "gptbot",
    "claudebot",
    "perplexitybot",
    "http-402",
    "x402",
    "crawler-toll",
    "ai-licensing",
    "tollbit",
    "skyfire",
    "context-license"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./bots": {
      "types": "./dist/bots.d.ts",
      "import": "./dist/bots.js",
      "require": "./dist/bots.cjs"
    },
    "./wba": {
      "types": "./dist/wba.d.ts",
      "import": "./dist/wba.js",
      "require": "./dist/wba.cjs"
    },
    "./http402": {
      "types": "./dist/http402.d.ts",
      "import": "./dist/http402.js",
      "require": "./dist/http402.cjs"
    },
    "./rsl": {
      "types": "./dist/rsl.d.ts",
      "import": "./dist/rsl.js",
      "require": "./dist/rsl.cjs"
    },
    "./insights": {
      "types": "./dist/insights.d.ts",
      "import": "./dist/insights.js",
      "require": "./dist/insights.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/bots.ts src/wba.ts src/http402.ts src/rsl.ts src/insights.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@noble/ed25519": "^2.2.3",
    "@noble/hashes": "^1.7.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
